{
  "name": "hotelospms",
  "version": "1.0.0",
  "description": "HotelOS PMS — Sistema de gestión hotelera completo",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "cd client && npm install && npm run build",
